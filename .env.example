# --- CONFIGURAÇÃO DO SUPABASE ---
# URL do projeto Supabase (ex: https://xyz.supabase.co)
VITE_SUPABASE_URL=

# Chave anônima pública do Supabase
VITE_SUPABASE_ANON_KEY=

# --- CONFIGURAÇÃO DA IA (GEMINI) ---
# Chave da API do Google Gemini (obtenha em https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# --- OUTRAS CONFIGURAÇÕES ---
# Porta do servidor de desenvolvimento (padrão: 3000)
PORT=3000
